---
import { getCollection, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Mermaid from "../../../components/Mermaid.astro";
import StatusBadge from "../../../components/StatusBadge.astro";
import { projectMeta } from "../../../data/projects";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const slug = entry.id.replace(/\.md$/, "");
const meta = projectMeta[slug];
---

<Layout
  title={meta?.title ?? slug}
  description={meta?.oneLiner}
  path={`development/projects/${slug}`}
>
  <article class="max-w-3xl mx-auto px-6 pt-16 pb-24">
    {meta && (
      <div class="mb-8 flex flex-wrap items-center gap-4">
        <StatusBadge status={meta.status} />
        <div class="flex flex-wrap gap-1.5">
          {meta.stack.map((t) => (
            <span class="font-mono text-[11px] px-2 py-0.5 rounded bg-surface border border-hairline text-muted">
              {t}
            </span>
          ))}
        </div>
      </div>
    )}

    <Mermaid>
      <div
        class="prose prose-neutral max-w-none
          prose-headings:font-display prose-headings:tracking-tight
          prose-h1:text-3xl prose-h2:text-xl prose-h2:mt-12 prose-h2:pb-2 prose-h2:border-b prose-h2:border-hairline
          prose-a:text-accent prose-a:no-underline hover:prose-a:underline
          prose-code:font-mono prose-code:text-[0.85em] prose-code:before:content-none prose-code:after:content-none
          prose-code:bg-surface prose-code:border prose-code:border-hairline prose-code:px-1 prose-code:py-0.5 prose-code:rounded
          prose-pre:bg-ink prose-pre:text-paper
          prose-strong:text-ink
          prose-hr:border-hairline
          prose-table:font-mono prose-table:text-sm
        "
      >
        <Content />
      </div>
    </Mermaid>
  </article>
</Layout>
