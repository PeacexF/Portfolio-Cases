---
import type { ProjectMeta } from "../data/projects";
import StatusBadge from "./StatusBadge.astro";

interface Props {
  slug: string;
  meta: ProjectMeta;
}
const { slug, meta } = Astro.props;
---

<a
  href={`/development/projects/${slug}`}
  class="group block rounded-lg border border-hairline bg-surface p-5 transition-colors hover:border-accent"
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-display font-semibold text-ink group-hover:text-accent transition-colors">
      {meta.title}
    </h3>
    <StatusBadge status={meta.status} />
  </div>
  <p class="mt-2 text-sm text-muted leading-relaxed">{meta.oneLiner}</p>
  <div class="mt-4 flex flex-wrap gap-1.5">
    {meta.stack.map((t) => (
      <span class="font-mono text-[11px] px-2 py-0.5 rounded bg-paper border border-hairline text-muted">
        {t}
      </span>
    ))}
  </div>
</a>
